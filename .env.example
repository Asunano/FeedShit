# ============================================================
# FeedShit 环境变量模板
# 复制为 .env 后填入真实值：cp .env.example .env
# 注意：本文件示例值不可直接用于生产，敏感变量切勿提交进版本库。
# ============================================================

# ---- 服务端口 / 数据目录 ----
PORT=8080
DATA_DIR=./data

# ---- 管理员账号（安装向导可覆盖并写入 DB） ----
ADMIN_USERNAME=admin
# 生产环境务必修改默认密码；安装完成后以 bcrypt 哈希存储于 DB。
ADMIN_PASSWORD=changeme

# ---- 链接 / 安全 ----
BASE_URL=http://localhost:8080
# PoW 难度（SHA-256 前导零位数，1–10）
POW_DIFFICULTY=4
# 每 IP 每小时提交上限（Docker 镜像默认覆盖为 3）
RATE_LIMIT_PER_HOUR=10
# 单请求最大上传体积 (MB)
MAX_UPLOAD_MB=20

# ---- 邮件通知（SMTP，按需配置） ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
# 明文仅用于「设置」页首次写入；落库后由主密钥加密（AES-GCM），备份/导出不含明文。
SMTP_PASS=
SMTP_FROM=
SMTP_TO=
NOTIFY_ENABLE=false

# ---- Webhook（已废弃） ----
# 全局 webhook_url 不再触发出站通知。请改用后台「Webhook 订阅」（带 HMAC 签名）。
# 此变量仅保留用于向后兼容显示，不参与任何出站。
WEBHOOK_URL=

# ---- 可信代理（用于读取真实客户端 IP） ----
# 逗号分隔的 IP 列表，* 表示全部；为空则只信任直连 IP。
TRUSTED_PROXIES=

# ---- 主加密密钥（必填，缺失即启动失败） ----
# AES-GCM 主密钥：32 字节原始值，或 64 位十六进制字符串。
# 仅通过环境变量提供，绝不写入数据库或配置表。
# 生成方式：head -c 32 /dev/urandom | xxd -p -c 32
FEEDSHIT_MASTER_KEY=

# ---- 外部 API Token 默认限速 ----
# 新建 API Token 未显式指定限速时套用的每小时上限。0 = 不限。
API_TOKEN_DEFAULT_RATE_LIMIT=60

# ---- 备份保留策略 ----
# 每日备份超过该天数的旧备份将被自动清理。0 = 不自动清理。
BACKUP_RETENTION_DAYS=30
